{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenTake",
  "version": "0.1.0",
  "identifier": "com.opentake.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "cwd": "..",
      "script": "pnpm -C web dev"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "pnpm -C web build"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenTake",
        "width": 1600,
        "height": 1000,
        "minWidth": 760,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 24 },
        "backgroundColor": "#0A0A0A",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
