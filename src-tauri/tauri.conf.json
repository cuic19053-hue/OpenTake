{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenTake",
  "version": "0.1.0",
  "identifier": "com.opentake.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "cwd": "..",
      "script": "pnpm -C web dev"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "pnpm -C web build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "OpenTake",
        "width": 1600,
        "height": 1000,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
